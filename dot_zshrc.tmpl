# ═══════════════════════════════════════════════════════════════════════════════
# ZSH Configuration - Managed by chezmoi
# ═══════════════════════════════════════════════════════════════════════════════
# OS: {{ .chezmoi.os }}
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────────
# Oh My Zsh Configuration
# ─────────────────────────────────────────────────────────────────────────────────
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME=""

# Plugins - add wisely, too many slow down startup
plugins=(
    fzf
    fzf-tab
    git
    zoxide
    zsh-autosuggestions
    zsh-completions
    zsh-syntax-highlighting
{{- if eq .chezmoi.os "darwin" }}
    macos            # macOS-specific commands (ofd, cdf, etc.)
{{- end }}
)

source $ZSH/oh-my-zsh.sh

eval "$(starship init zsh)"

# ─────────────────────────────────────────────────────────────────────────────────
# Environment Variables (Cross-Platform)
# ─────────────────────────────────────────────────────────────────────────────────
export EDITOR="vim"
export LANG="en_US.UTF-8"
if command -v bat &>/dev/null; then
    export PAGER="bat"
    export MANPAGER="sh -c 'col -bx | bat -l man -p'"
fi

# Default Python venv
if [[ -f "$HOME/.venvs/default/bin/activate" ]]; then
    source "$HOME/.venvs/default/bin/activate"
fi

# ─────────────────────────────────────────────────────────────────────────────────
# PATH Configuration
# ─────────────────────────────────────────────────────────────────────────────────
{{- if eq .chezmoi.os "darwin" }}
# macOS: Homebrew paths (Apple Silicon)
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:$PATH"
{{- else if eq .chezmoi.os "linux" }}
# Linux: Linuxbrew (if installed)
if [[ -d "/home/linuxbrew/.linuxbrew" ]]; then
    export PATH="/home/linuxbrew/.linuxbrew/bin:$PATH"
fi
{{- end }}

# User scripts
export PATH="$HOME/.local/bin:$PATH"

# ─────────────────────────────────────────────────────────────────────────────────
# SSH Agent Configuration
# ─────────────────────────────────────────────────────────────────────────────────
{{- if eq .chezmoi.os "darwin" }}
# macOS: Use Keychain to remember SSH passphrases
# Keys are automatically added when first used
{{- else if eq .chezmoi.os "linux" }}
# Linux/WSL: Start ssh-agent if not running
if [[ -z "$SSH_AUTH_SOCK" ]]; then
    eval "$(ssh-agent -s)" > /dev/null 2>&1
fi
{{- end }}

# ─────────────────────────────────────────────────────────────────────────────────
# Aliases (Cross-Platform)
# ─────────────────────────────────────────────────────────────────────────────────
alias g="git"
alias gs="git status"
alias gd="git diff"
alias gl="git lg"
alias gp="git push"
alias gpu="git pull"

# eza aliases (replaces ls)
if command -v eza &>/dev/null; then
    alias ls="eza --icons"
    alias ll="eza -la --icons --git"
    alias la="eza -la --icons --git --all"
    alias tree="eza --tree --icons"
fi

# Quick navigation
alias ..="cd .."
alias ...="cd ../.."
alias code="cd ~/Code"

# ─────────────────────────────────────────────────────────────────────────────────
# OS-Specific Configuration
# ─────────────────────────────────────────────────────────────────────────────────
{{- if eq .chezmoi.os "darwin" }}
# macOS-specific aliases and settings
alias brewup="brew update && brew upgrade && brew cleanup"
alias flushdns="sudo dscacheutil -flushcache; sudo killall -HUP mDNSResponder"
{{- end }}

{{- if and (eq .chezmoi.os "linux") (env "WSL_DISTRO_NAME") }}
# WSL-specific: Integration with Windows
alias explorer="explorer.exe"
alias clip="clip.exe"
alias open="wslview"

# Access Windows home directory
export WIN_HOME="/mnt/c/Users/$(cmd.exe /c 'echo %USERNAME%' 2>/dev/null | tr -d '\r\n')"
{{- end }}

# ─────────────────────────────────────────────────────────────────────────────────
# Secrets (API keys, tokens) - NEVER commit this file!
# ─────────────────────────────────────────────────────────────────────────────────
if [[ -f "$HOME/.secrets" ]]; then
    source "$HOME/.secrets"
fi

# ─────────────────────────────────────────────────────────────────────────────────
# GitHub CLI: explicit per-account invocation (no Keychain)
# ─────────────────────────────────────────────────────────────────────────────────
gh-personal() { GH_TOKEN="$GH_PERSONAL_TOKEN" gh "$@"; }
gh-work()     { GH_TOKEN="$GH_WORK_TOKEN"     gh "$@"; }
