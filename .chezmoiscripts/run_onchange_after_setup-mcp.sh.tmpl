#!/bin/bash
# Post-apply setup: generate mcp-servers.json with correct paths, then merge
# into ~/.claude.json using the mirus-tech setup script.
#
# Re-runs whenever the encrypted secrets blob or this script changes.
# secrets hash: {{ include ".local/secrets/encrypted_private_dot_secrets.age" | sha256sum }}

set -euo pipefail

CLAUDE_DIR="{{ .chezmoi.homeDir }}/.claude"
MCP_JSON="$CLAUDE_DIR/mcp-servers.json"
MCP_SCRIPT="$CLAUDE_DIR/scripts/setup-mcp-servers.sh"

# Source secrets for CONTEXT7_API_KEY
if [[ -f "$HOME/.secrets" ]]; then
    source "$HOME/.secrets"
fi

if [[ -z "${CONTEXT7_API_KEY:-}" ]]; then
    echo "WARN: CONTEXT7_API_KEY not set — skipping MCP setup."
    echo "      This is expected on first apply before ~/.secrets is decrypted."
    echo "      Once the age key is in place and ~/.secrets exists, re-run:"
    echo "          chezmoi apply"
    exit 0
fi

# Generate mcp-servers.json with machine-local paths and API key from env
cat > "$MCP_JSON" <<MCPEOF
{
  "context7": {
    "type": "http",
    "url": "https://mcp.context7.com/mcp",
    "headers": {
      "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
    }
  },
  "serena": {
    "type": "stdio",
    "command": "uvx",
    "args": [
      "--from",
      "git+https://github.com/oraios/serena",
      "serena",
      "start-mcp-server",
      "--context",
      "claude-code",
      "--project",
      "{{ .chezmoi.homeDir }}",
      "--open-web-dashboard",
      "false"
    ],
    "env": {}
  }
}
MCPEOF

echo "Generated $MCP_JSON"

# Merge into ~/.claude.json using mirus-tech script
if [[ -x "$MCP_SCRIPT" ]] && command -v jq &>/dev/null; then
  "$MCP_SCRIPT"
else
  echo "Falling back to claude mcp add..."
  if command -v claude &>/dev/null; then
    claude mcp remove --scope user serena 2>/dev/null || true
    claude mcp remove --scope user context7 2>/dev/null || true

    claude mcp add --scope user --transport stdio serena -- \
      uvx --from git+https://github.com/oraios/serena \
      serena start-mcp-server \
      --context claude-code \
      --project {{ .chezmoi.homeDir }} \
      --open-web-dashboard False

    claude mcp add --scope user --transport http \
      --header "CONTEXT7_API_KEY: ${CONTEXT7_API_KEY}" \
      context7 \
      -- https://mcp.context7.com/mcp

    echo "MCP servers configured via claude CLI"
  else
    echo "Neither setup-mcp-servers.sh+jq nor claude CLI available"
    echo "MCP servers NOT configured — run manually after installing dependencies"
  fi
fi
