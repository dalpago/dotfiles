#!/bin/bash
# packages.yaml hash: {{ include ".chezmoidata/packages.yaml" | sha256sum }} {{ if stat (joinPath .chezmoi.sourceDir ".local/.chezmoidata/local.yaml") }}{{ include (joinPath ".local/.chezmoidata/local.yaml") | sha256sum }}{{ end }}
set -euo pipefail

# Merge base + enabled categories via Python
MERGED_JSON=$(python3 - << 'PYEOF'
import json, sys

enabled = {{ dig "enabledCategories" list . | toJson }}
base = {{ dig "base" dict . | toJson }}
categories = {{ dig "categories" dict . | toJson }}

def merge_lists(a, b):
    return list(dict.fromkeys(a + b))

darwin_brews = list(base.get('darwin', {}).get('brews', []))
darwin_casks = list(base.get('darwin', {}).get('casks', []))
debian_apt = list(base.get('debian', {}).get('apt', []))
npm_pkgs = []

for cat in enabled:
    c = categories.get(cat, {})
    darwin_brews = merge_lists(darwin_brews, c.get('darwin', {}).get('brews', []))
    darwin_casks = merge_lists(darwin_casks, c.get('darwin', {}).get('casks', []))
    debian_apt = merge_lists(debian_apt, c.get('debian', {}).get('apt', []))
    npm_pkgs = merge_lists(npm_pkgs, c.get('npm', []))

print(json.dumps({
    'darwin_brews': darwin_brews,
    'darwin_casks': darwin_casks,
    'debian_apt': debian_apt,
    'npm': npm_pkgs,
}))
PYEOF
)

DARWIN_BREWS=$(echo "$MERGED_JSON" | python3 -c "import json,sys; d=json.load(sys.stdin); print('\n'.join(d['darwin_brews']))")
DARWIN_CASKS=$(echo "$MERGED_JSON" | python3 -c "import json,sys; d=json.load(sys.stdin); print('\n'.join(d['darwin_casks']))")
DEBIAN_APT=$(echo "$MERGED_JSON" | python3 -c "import json,sys; d=json.load(sys.stdin); print('\n'.join(d['debian_apt']))")
NPM_PKGS=$(echo "$MERGED_JSON" | python3 -c "import json,sys; d=json.load(sys.stdin); print('\n'.join(d['npm']))")

{{ if eq .osid "darwin" -}}
# ===========================================================================
# macOS — Homebrew
# ===========================================================================

if ! command -v brew &>/dev/null; then
    echo "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

echo "Installing Homebrew packages..."
brew bundle --file=/dev/stdin <<BREWEOF
$(echo "$DARWIN_BREWS" | while IFS= read -r pkg; do [[ -n "$pkg" ]] && echo "brew \"$pkg\""; done)
$(echo "$DARWIN_CASKS" | while IFS= read -r pkg; do [[ -n "$pkg" ]] && echo "cask \"$pkg\""; done)
BREWEOF

{{ else if eq .osid "debian" -}}
# ===========================================================================
# Debian / Ubuntu / WSL — apt + manual installs
# ===========================================================================

echo "Updating apt package index..."
sudo apt update -y

echo "Installing apt packages..."
sudo apt install -y $(echo "$DEBIAN_APT" | tr '\n' ' ')

# --- Manual installs for tools not in standard apt repos ---

# zoxide
if ! command -v zoxide &>/dev/null; then
    echo "Installing zoxide..."
    curl -sSfL https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | sh
fi

# eza
if ! command -v eza &>/dev/null; then
    echo "Installing eza..."
    sudo mkdir -p /etc/apt/keyrings
    wget -qO- https://raw.githubusercontent.com/eza-community/eza/main/deb.asc | sudo gpg --dearmor -o /etc/apt/keyrings/gierens.gpg
    echo "deb [signed-by=/etc/apt/keyrings/gierens.gpg] http://deb.gierens.de stable main" | sudo tee /etc/apt/sources.list.d/gierens.list
    sudo chmod 644 /etc/apt/keyrings/gierens.gpg /etc/apt/sources.list.d/gierens.list
    sudo apt update -y
    sudo apt install -y eza
fi

# git-delta
if ! command -v delta &>/dev/null; then
    echo "Installing git-delta..."
    DELTA_VERSION=$(curl -sSf https://api.github.com/repos/dandavison/delta/releases/latest | grep -oP '"tag_name":\s*"\K[^"]+')
    ARCH=$(dpkg --print-architecture)
    curl -sSfLO "https://github.com/dandavison/delta/releases/download/${DELTA_VERSION}/git-delta_${DELTA_VERSION}_${ARCH}.deb"
    sudo dpkg -i "git-delta_${DELTA_VERSION}_${ARCH}.deb"
    rm -f "git-delta_${DELTA_VERSION}_${ARCH}.deb"
fi

# age
if ! command -v age &>/dev/null; then
    echo "Installing age..."
    sudo apt install -y age 2>/dev/null || {
        AGE_VERSION=$(curl -sSf https://api.github.com/repos/FiloSottile/age/releases/latest | grep -oP '"tag_name":\s*"\K[^"]+')
        ARCH=$(dpkg --print-architecture)
        curl -sSfLO "https://github.com/FiloSottile/age/releases/download/${AGE_VERSION}/age-${AGE_VERSION}-linux-${ARCH}.tar.gz"
        sudo tar -xzf "age-${AGE_VERSION}-linux-${ARCH}.tar.gz" -C /usr/local/bin --strip-components=1 age/age age/age-keygen
        rm -f "age-${AGE_VERSION}-linux-${ARCH}.tar.gz"
    }
fi

# starship (Linux fallback)
if ! command -v starship &>/dev/null; then
    echo "Installing starship..."
    curl -sS https://starship.rs/install.sh | sh -s -- --yes
fi

# uv (Linux)
if ! command -v uv &>/dev/null; then
    echo "Installing uv..."
    curl -LsSf https://astral.sh/uv/install.sh | sh
fi

# Node.js via NodeSource LTS (needed for npm packages)
if ! command -v node &>/dev/null; then
    echo "Installing Node.js LTS..."
    curl -fsSL https://deb.nodesource.com/setup_lts.x | sudo -E bash -
    sudo apt install -y nodejs
fi

{{ end -}}

# ===========================================================================
# Cross-platform — npm global packages
# ===========================================================================

if command -v npm &>/dev/null; then
    echo "Installing npm global packages..."
    while IFS= read -r pkg; do
        [[ -z "$pkg" ]] && continue
        if ! npm list -g "$pkg" &>/dev/null; then
            npm install -g "$pkg"
        fi
    done <<< "$NPM_PKGS"
fi

# ===========================================================================
# Cross-platform — uv default venv
# ===========================================================================

if command -v uv &>/dev/null; then
    echo "Setting up default Python venv at ~/.venvs/default..."
    mkdir -p ~/.venvs
    if [[ ! -d ~/.venvs/default ]]; then
        uv venv ~/.venvs/default
    fi
    UV_PYTHON_PACKAGES='{{ dig "uv_python" "packages" list . | toJson }}'
    export VENV_PYTHON="$HOME/.venvs/default/bin/python"
    echo "$UV_PYTHON_PACKAGES" | python3 -c "
import json, sys, os, subprocess
pkgs = json.load(sys.stdin)
venv_python = os.environ['VENV_PYTHON']
if pkgs:
    subprocess.run(['uv', 'pip', 'install', '--python', venv_python] + pkgs, check=True)
"
fi
