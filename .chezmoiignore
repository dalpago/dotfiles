# ═══════════════════════════════════════════════════════════════════════════════
# chezmoi Ignore Rules
# ═══════════════════════════════════════════════════════════════════════════════
# Files listed here will NOT be managed by chezmoi.
# Supports templates: you can ignore files based on OS.
# ═══════════════════════════════════════════════════════════════════════════════

# Always ignore
README.md
LICENSE

# Ignore SSH private keys - these are generated per machine, not synced
.ssh/github-personal
.ssh/github-work
.ssh/csi-data
.ssh/known_hosts
.ssh/known_hosts.old

# macOS-only files - ignore on Linux
{{ if ne .chezmoi.os "darwin" }}
Library/
{{ end }}

# Linux-only files - ignore on macOS
{{ if ne .chezmoi.os "linux" }}
.config/systemd/
{{ end }}

# oh-my-zsh cache
.oh-my-zsh/cache/**

# Claude runtime data — do not manage these via chezmoi
.claude/settings.local.json
.claude/projects/**
.claude/plans/**
.claude/memory/**
.claude/debug/**
.claude/history.jsonl
.claude/telemetry/**
.claude/todos/**
.claude/session-env/**
.claude/shell-snapshots/**
.claude/file-history/**
.claude/cache/**
.claude/backups/**
.claude/tasks/**
.claude/.credentials.json
.claude/statsig/**
.claude/ide/**
.claude/paste-cache/**
.claude/downloads/**
