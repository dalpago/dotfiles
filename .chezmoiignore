# ═══════════════════════════════════════════════════════════════════════════════
# chezmoi Ignore Rules
# ═══════════════════════════════════════════════════════════════════════════════
# Files listed here will NOT be managed by chezmoi.
# Supports templates: you can ignore files based on OS.
#
# Note: this file is distinct from the `exclude` lists in
# .chezmoiexternal.toml.tmpl. The two solve different problems:
#   - external `exclude` blocks files from being PULLED from upstream
#     (e.g. settings.json from the claude-config repo).
#   - .chezmoiignore blocks chezmoi from MANAGING files that exist locally
#     as user runtime data (e.g. ~/.claude/projects/, history.jsonl).
# Don't conflate them. If a file should never enter the source tree, use
# external `exclude`. If it enters but must not be deployed/diffed, ignore here.
# ═══════════════════════════════════════════════════════════════════════════════

# Always ignore
README.md
LICENSE

# chezmoi pre-hook script — referenced directly from chezmoi.toml,
# not a user dotfile. Must not deploy to $HOME.
sync-staging.sh

# Ignore SSH private keys - these are generated per machine, not synced
.ssh/github-personal
.ssh/github-work
.ssh/csi-data
.ssh/known_hosts
.ssh/known_hosts.old

# macOS-only files - ignore on Linux
{{ if ne .chezmoi.os "darwin" }}
Library/
{{ end }}

# Linux-only files - ignore on macOS
{{ if ne .chezmoi.os "linux" }}
.config/systemd/
{{ end }}

# oh-my-zsh cache
.oh-my-zsh/cache/**

# Claude runtime data — do not manage these via chezmoi
.claude/settings.local.json
.claude/projects/**
.claude/plans/**
.claude/memory/**
.claude/debug/**
.claude/history.jsonl
.claude/telemetry/**
.claude/todos/**
.claude/session-env/**
.claude/shell-snapshots/**
.claude/file-history/**
.claude/cache/**
.claude/backups/**
.claude/tasks/**
.claude/.credentials.json
.claude/statsig/**
.claude/ide/**
.claude/paste-cache/**
.claude/downloads/**
